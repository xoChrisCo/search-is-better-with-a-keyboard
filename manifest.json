{
  "manifest_version": 3,
  "name": "Search Keyboard Nav",
  "version": "1.1.0",
  "description": "Keyboard navigation for Google and DuckDuckGo search results: Tab/Shift+Tab and Arrow keys jump between results.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*", "https://duckduckgo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
